# .env.example — Template for machine-specific configuration
# ============================================================
# Copy this file to .env and fill in YOUR machine paths.
# The .env file is gitignored so your paths/keys are never uploaded to GitHub.
#
# HOW TO SET UP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in each value below
#   3. Run the pipeline — it reads from .env automatically

# ── Claude API ───────────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Drive (optional) ──────────────────────────────────────────────────
# The folder ID from your Google Drive URL. Leave blank to skip Drive upload.
# Example: https://drive.google.com/drive/folders/1AbCdEfGhIjKlMnOpQrStUvWx
#                                                  ^^^^^^^^^^^^^^^^^^^^^^^^^ this part
GOOGLE_DRIVE_FOLDER_ID=

# ── After Effects ────────────────────────────────────────────────────────────
AERENDER_PATH=C:/Program Files/Adobe/Adobe After Effects 2026/Support Files/aerender.exe

# ── Cinema 4D ────────────────────────────────────────────────────────────────
C4D_EXE=C:/Program Files/Maxon Cinema 4D 2026/Cinema 4D.exe

# Folder where C4D saves greyscale scene renders (used as ControlNet inputs)
C4D_RENDERS_DIR=C:/path/to/your/c4d/renders

# Filenames of the specific C4D renders to use per scene
C4D_RENDER_SAX=saxophone_model1_16x9_014.png
C4D_RENDER_PIANO=piano_grand_16x9_008.png
C4D_RENDER_GUITAR=guitar_16x9_001.png

# Paths to C4D Python scripts (launched by dashboard Step 1 buttons)
C4D_SCRIPT_SAX=C:/path/to/yosuki_saxophone_16x9.py
C4D_SCRIPT_PIANO=C:/path/to/yosuki_piano_16x9.py
C4D_SCRIPT_GUITAR=C:/path/to/yosuki_guitar_16x9.py
C4D_SCRIPT_ALL=C:/path/to/yosuki_c4d_pipeline_v3.py

# ── ComfyUI ──────────────────────────────────────────────────────────────────
# URL of your local ComfyUI server (usually this default is correct)
COMFYUI_URL=http://127.0.0.1:8188

# Folder where ComfyUI Desktop saves generated images
COMFYUI_OUTPUT_DIR=G:/ComfyUI/output

# ── Asset bundle ─────────────────────────────────────────────────────────────
# Path to the fde_asset_bundle folder (product images, logo, etc.)
ASSET_BUNDLE_DIR=C:/path/to/fde_asset_bundle
